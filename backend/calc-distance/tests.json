{
  "tests": [
    {
      "name": "OPTIONS CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing params returns 400",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400
    },
    {
      "name": "Calc distance Moscow to SPb",
      "method": "POST",
      "path": "/",
      "body": {"from": "Москва", "to": "Санкт-Петербург"},
      "expectedStatus": 200
    },
    {
      "name": "Calc Moscow to Bryansk with regions",
      "method": "POST",
      "path": "/",
      "body": {"from": "Москва, Москва", "to": "Брянск, Брянская область"},
      "expectedStatus": 200
    },
    {
      "name": "Calc Moscow to small town Hotkovo",
      "method": "POST",
      "path": "/",
      "body": {"from": "Москва, Москва", "to": "г Хотьково, Московская область"},
      "expectedStatus": 200
    },
    {
      "name": "Multi points needs at least 2",
      "method": "POST",
      "path": "/",
      "body": {"points": ["Москва"]},
      "expectedStatus": 400
    }
  ]
}