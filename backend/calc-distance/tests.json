{
  "tests": [
    {
      "name": "OPTIONS CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing params returns 400",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Calc distance Moscow to SPb",
      "method": "POST",
      "path": "/",
      "body": {"from": "Москва", "to": "Санкт-Петербург"},
      "expectedStatus": 200,
      "expectedBody": {"distance": "number"},
      "bodyMatcher": "partial"
    }
  ]
}
