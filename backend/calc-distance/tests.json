{
  "tests": [
    {
      "name": "OPTIONS CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing params returns 400",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {"error": "from and to are required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Calc distance Moscow to SPb",
      "method": "POST",
      "path": "/",
      "body": {"from": "Москва", "to": "Санкт-Петербург"},
      "expectedStatus": 200,
      "expectedBody": {"distance": 708},
      "bodyMatcher": "partial"
    },
    {
      "name": "Multi points needs at least 2",
      "method": "POST",
      "path": "/",
      "body": {"points": ["Москва"]},
      "expectedStatus": 400,
      "expectedBody": {"error": "need at least 2 points"},
      "bodyMatcher": "partial"
    }
  ]
}