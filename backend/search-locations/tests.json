{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Empty query returns empty",
      "method": "POST",
      "path": "/",
      "body": {"query": ""},
      "expectedStatus": 200
    },
    {
      "name": "Search city returns suggestions",
      "method": "POST",
      "path": "/",
      "body": {"query": "Брянск"},
      "expectedStatus": 200
    },
    {
      "name": "Search small town Hotkovo",
      "method": "POST",
      "path": "/",
      "body": {"query": "Хотьково"},
      "expectedStatus": 200
    },
    {
      "name": "Search village",
      "method": "POST",
      "path": "/",
      "body": {"query": "Простоквашино"},
      "expectedStatus": 200
    }
  ]
}